{
    "name": "helsingborg-stad/wpmu-security",
    "description": "A WordPress MU Plugin for security enhancements",
    "type": "wordpress-muplugin",
    "license": "MIT",
    "scripts": {
        "test": "./vendor/bin/phpunit --testdox",
        "test:coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --testdox",
        "minimal": "./vendor/bin/phpunit",
        "lint": "vendor/bin/mago lint",
        "fix": "vendor/bin/mago lint --format-after-fix --fix",
        "format": "vendor/bin/mago fmt"
    },
    "authors": [
        {
            "name": "Sebastian Thulin",
            "email": "sebastian.thulin@helsingborg.se"
        }
    ],
    "autoload": {
        "psr-4": {
            "WPMUSecurity\\": "source/php/"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "helsingborg-stad/wpservice": "^2.0",
        "helsingborg-stad/acfservice": "^1.3",
        "helsingborg-stad/acf-export-manager": "^1.0"
    },
    "require-dev": {
        "brain/monkey": "^2.6",
        "codedungeon/phpunit-result-printer": "^0.31.0",
        "phpunit/phpunit": "^9.5",
        "php-stubs/wordpress-stubs": "^6.8",
        "carthage-software/mago": "^1.14.1"
    },
    "suggest": {
        "helsingborg-stad/municipio": "^6.0.0"
    },
    "config": {
        "allow-plugins": {
            "carthage-software/mago": true
        }
    },
    "version": "1.9.1"
}